# Environment Configuration for Kiln Staking Contracts Research
# Copy this file to .env in your workspace and fill in your values

# Required: Mainnet RPC URL for forking
# Get a free API key from https://www.alchemy.com/
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Optional: Other RPC endpoints
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE
HOLESKY_RPC_URL=https://eth-holesky.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Optional: Etherscan API key for contract verification
# Get a free API key from https://etherscan.io/apis
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE

# Target contract information (for reference)
TARGET_CONTRACT=0xdc71affc862fceb6ad32be58e098423a7727bebd
TARGET_NETWORK=mainnet
FORK_BLOCK_NUMBER=18500000

# Optional: Private key for testing (NEVER use real funds!)
# Only needed if you want to test actual transactions
# PRIVATE_KEY=0x...

# Optional: Foundry settings override
# FOUNDRY_PROFILE=default
# FOUNDRY_FUZZ_RUNS=256
# FOUNDRY_VERBOSITY=3

# HackenProof program information (for reference)
PROGRAM_URL=https://dashboard.hackenproof.com/user/programs/metamask-validator-staking-smart-contracts
SUBMIT_URL=https://dashboard.hackenproof.com/user/programs/metamask-validator-staking-smart-contracts/reports/new

# Repository information (for reference)
TARGET_REPO=https://github.com/kilnfi/staking-contracts
TARGET_COMMIT=f33eb8dc37fab40217dbe1e69853ca3fcd884a2d
