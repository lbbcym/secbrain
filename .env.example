# SecBrain Environment Variables
# Copy this file to .env and fill in your API keys

# Research Integration (Required for non-dry-run mode)
# Get your API key from https://www.perplexity.ai/
PERPLEXITY_API_KEY=pplx-your-key-here

# Advisor Model (Required for non-dry-run mode)
# Get your API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza-your-key-here

# Worker Model (Required for non-dry-run mode - choose ONE)
# Option 1: Together AI (Recommended - fastest and cheapest)
# Get your API key from https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-key-here

# Option 2: OpenRouter (Alternative)
# Get your API key from https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-key-here

# Option 3: OpenAI (Alternative - most expensive)
# Get your API key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-key-here

# Optional: Custom OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.together.xyz/v1

# Note: In dry-run mode (default), API keys are not required.
# The system will use mock responses instead.
